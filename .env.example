# Server
HOST=0.0.0.0
PORT=1337
URL=

# Secrets (auto-generated if not provided)
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
JWT_SECRET=
TRANSFER_TOKEN_SALT=

# Database (default: SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# External Database (PostgreSQL/MySQL)
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=
# DATABASE_SSL=false
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# DATABASE_POOL_ACQUIRE_TIMEOUT=30000
# DATABASE_POOL_IDLE_TIMEOUT=30000

# Upload Provider (local|aws-s3|cloudinary)
UPLOAD_PROVIDER=local

# S3/MinIO Upload Configuration
# UPLOAD_PROVIDER=aws-s3
# S3_ENDPOINT=
# S3_REGION=us-east-1
# S3_BUCKET=
# S3_PREFIX=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ACL=private
# S3_BASE_URL=
# S3_PARAMS={}

# Cloudinary Upload Configuration
# UPLOAD_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Email Provider (none|smtp|sendgrid)
EMAIL_PROVIDER=none
EMAIL_DEFAULT_FROM=noreply@example.com
EMAIL_DEFAULT_REPLY_TO=

# SMTP Configuration
# EMAIL_PROVIDER=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_IGNORE_TLS=false

# SendGrid Configuration
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=

# Admin Panel
ADMIN_PATH=/admin
ADMIN_AUTO_OPEN=false
ADMIN_JWT_EXPIRATION=7d
ADMIN_RATE_LIMIT_ENABLED=true
ADMIN_RATE_LIMIT_MAX=5
ADMIN_RATE_LIMIT_TIME_WINDOW=900000
ADMIN_FORGOT_PASSWORD_ENABLED=true

# GraphQL
GRAPHQL_ENDPOINT=/graphql
GRAPHQL_PLAYGROUND_ENABLED=false
GRAPHQL_INTROSPECTION=false
GRAPHQL_MAX_DEPTH=10
GRAPHQL_MAX_COMPLEXITY=1000
GRAPHQL_APOLLO_SANDBOX=false

# API
API_REST_DEFAULT_LIMIT=25
API_REST_MAX_LIMIT=100

# Body Parser
BODY_PARSER_JSON_LIMIT=1mb
BODY_PARSER_FORM_LIMIT=56kb
BODY_PARSER_TEXT_LIMIT=1mb

# Performance
NODE_OPTIONS=
LOG_LEVEL=info
LOG_PRETTY_PRINT=false
LOG_FORCE_JSON=true

# Node Environment
NODE_ENV=production

# Telemetry
STRAPI_TELEMETRY_DISABLED=true

# Documentation Plugin
DOCUMENTATION_ENABLED=false

# Sentry (optional)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Flags
FLAG_NPS=false
FLAG_PROMOTE_EE=false
